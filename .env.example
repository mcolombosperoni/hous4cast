# Base path used by Vite for GitHub Pages deployment
VITE_BASE_PATH=

# Public URL used by admin QR generation
VITE_PUBLIC_BASE_URL=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloudinary unsigned upload (no secret required — see ADR 0012)
# cloud_name from Cloudinary dashboard top-left
VITE_CLOUDINARY_CLOUD_NAME=
# unsigned upload preset name (Settings > Upload > Upload presets)
VITE_CLOUDINARY_UPLOAD_PRESET=

